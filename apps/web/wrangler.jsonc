{
	"name": "phonia",
	"compatibility_date": "2026-07-01",
	"assets": {
		"directory": "./build",
		"not_found_handling": "single-page-application"
	},
	"routes": [
		{ "pattern": "phonia.app", "custom_domain": true },
		{ "pattern": "about.phonia.app", "custom_domain": true }
	],
	"observability": { "enabled": true }
}
